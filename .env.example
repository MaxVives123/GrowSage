# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deploying

# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when PostgreSQL plugin is added.
# For local dev, SQLite is used by default (no need to set this).
# DATABASE_URL=postgresql://user:pass@host:5432/sproutai

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, set this to your Railway frontend URL.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
DAILY_REQUEST_LIMIT=30

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Path where ChromaDB persists its data.
# RAILWAY: Add a Volume in the Railway dashboard mounted at /app/vectorstore
#          so the index survives redeploys. Set this var to /app/vectorstore.
CHROMA_PERSIST_DIR=vectorstore

# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry DSN for error tracking. Get it from sentry.io > Project > Settings > DSN.
# Leave empty to disable Sentry (safe for local dev).
# SENTRY_DSN=https://xxxxx@oXXXXX.ingest.sentry.io/XXXXXXX

# ── Email ─────────────────────────────────────────────────────────────────────
# Resend API key for transactional email (registration verification).
# Get it from resend.com > API Keys. Without this, verification links are
# printed to console (development mode).
# RESEND_API_KEY=re_xxxxxxxx

# ── Redis ─────────────────────────────────────────────────────────────────────
# RAILWAY: Add a Redis plugin — it injects REDIS_URL automatically.
# Without Redis, rate limiting and caching degrade gracefully (app still works).
# REDIS_URL=redis://localhost:6379

# ── URLs (for email links and CORS) ───────────────────────────────────────────
# BACKEND_URL=https://your-backend.railway.app
# FRONTEND_URL=https://your-frontend.railway.app
